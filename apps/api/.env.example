# App
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Database (PostgreSQL / Google Cloud SQL)
DATABASE_URL="postgresql://user:password@localhost:5432/fluxowork?schema=public"

# Cache / filas (Redis / Memorystore)
REDIS_URL="redis://localhost:6379"

# Autenticação (Google OAuth 2.0)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Storage (Google Cloud Storage)
GCS_BUCKET_NAME=
GCS_PROJECT_ID=
# Em produção, usar Workload Identity / conta de serviço padrão do Cloud Run;
# GOOGLE_APPLICATION_CREDENTIALS só é necessário em desenvolvimento local.
GOOGLE_APPLICATION_CREDENTIALS=

# CNPJá — validação de CNPJ do prestador
CNPJA_API_KEY=

# PlugNotas — emissão de NFS-e
PLUGNOTAS_API_KEY=

# Clicksign — assinatura digital de contratos
CLICKSIGN_ACCESS_TOKEN=

# Stark Bank — PIX, boleto, transferência, CNAB
STARKBANK_PROJECT_ID=
STARKBANK_PRIVATE_KEY=

# Resend — e-mails transacionais
RESEND_API_KEY=
