// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SUPERVISOR
  GERENTE
  FINANCEIRO
  PRESTADOR
}

enum MembershipStatus {
  INVITED
  ACTIVE
  REVOKED
}

enum ProviderStatus {
  ACTIVE
  INACTIVE
}

enum AgreementType {
  HOURLY
  FIXED_PER_ACTIVITY
  MONTHLY
}

enum AgreementStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum ContractTemplateStatus {
  ACTIVE
  ARCHIVED
}

enum ContractStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  TERMINATED
}

enum SignatureStatus {
  PENDING
  SIGNED
}

enum ServiceOrderStatus {
  PENDING_MANAGER_APPROVAL
  PENDING_FINANCE_APPROVAL
  ADJUSTMENT_REQUESTED
  APPROVED
  REJECTED
  CANCELLED
}

model Company {
  id        String   @id @default(cuid())
  legalName String
  tradeName String?
  cnpj      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships          Membership[]
  auditLogs            AuditLog[]
  providers            Provider[]
  commercialAgreements CommercialAgreement[]
  contractTemplates    ContractTemplate[]
  contracts            Contract[]
  serviceOrders        ServiceOrder[]
  approvalLevels       ApprovalLevel[]
  hierarchyAssignments HierarchyAssignment[]

  @@map("companies")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships   Membership[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]     @relation("AuditActor")

  createdServiceOrders ServiceOrder[] @relation("ServiceOrderCreatedBy")
  managerDecisions     ServiceOrder[] @relation("ServiceOrderManagerDecision")
  financeDecisions     ServiceOrder[] @relation("ServiceOrderFinanceDecision")

  hierarchyAssignments HierarchyAssignment[]

  @@map("users")
}

// Vínculo entre um Usuário e uma Empresa, com o papel exercido nela.
// Um usuário pode ter vínculos com várias empresas (relação global de identidade).
model Membership {
  id         String           @id @default(cuid())
  userId     String
  companyId  String
  role       Role
  status     MembershipStatus @default(INVITED)
  invitedAt  DateTime         @default(now())
  acceptedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
  @@map("memberships")
}

// companyId/role são um snapshot do escopo de empresa ativo no momento da emissão
// (o usuário pode ter vínculos com várias empresas — o refresh precisa lembrar qual).
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  companyId String?
  role      Role?
  tokenHash String    @unique
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

// Trilha de auditoria transversal — todo módulo de negócio futuro escreve aqui
// a cada transição de estado relevante (spec seção 3 e 4.12).
model AuditLog {
  id          String   @id @default(cuid())
  companyId   String?
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  ip          String?
  context     Json?
  createdAt   DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id])
  actor   User?    @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([companyId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// Cadastro PJ do prestador (spec 4.2) — só o cadastro simples + dados de CNPJ.
// Abertura de MEI / conta PJ digital ficam fora desta fatia (dependem de um
// parceiro externo ainda não definido pelo spec). Sem vínculo com User/Membership
// ainda — Prestador aqui é só dado gerenciado pela empresa, não um login.
model Provider {
  id                      String         @id @default(cuid())
  companyId               String
  cnpj                    String
  legalName               String
  tradeName               String?
  contactName             String
  cpf                     String
  rg                      String?
  address                 Json?
  status                  ProviderStatus @default(ACTIVE)
  responsibleAssignmentId String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  company               Company               @relation(fields: [companyId], references: [id])
  commercialAgreements  CommercialAgreement[]
  contracts             Contract[]
  serviceOrders         ServiceOrder[]
  responsibleAssignment HierarchyAssignment?  @relation(fields: [responsibleAssignmentId], references: [id])

  @@unique([companyId, cnpj])
  @@map("providers")
}

// Histórico de acordos comerciais de um prestador — nunca sobrescrito; um novo
// acordo ACTIVE encerra (TERMINATED) o anterior em vez de substituí-lo.
model CommercialAgreement {
  id               String          @id @default(cuid())
  companyId        String
  providerId       String
  type             AgreementType
  baseRate         Decimal         @db.Decimal(12, 2)
  scopeDescription String
  status           AgreementStatus @default(ACTIVE)
  startDate        DateTime
  endDate          DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  company       Company        @relation(fields: [companyId], references: [id])
  provider      Provider       @relation(fields: [providerId], references: [id])
  serviceOrders ServiceOrder[]

  @@index([providerId])
  @@map("commercial_agreements")
}

// Modelo de contrato por tipo de atividade (spec 4.3). activityType é texto livre
// por enquanto — a entidade Atividade (spec 4.4) ainda não existe.
model ContractTemplate {
  id           String                 @id @default(cuid())
  companyId    String
  name         String
  activityType String
  bodyTemplate String
  status       ContractTemplateStatus @default(ACTIVE)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  company   Company    @relation(fields: [companyId], references: [id])
  contracts Contract[]

  @@map("contract_templates")
}

// Histórico de versões de contrato de um prestador — nunca sobrescrito; um novo
// contrato ACTIVE encerra (SUPERSEDED) o anterior, mesmo padrão de CommercialAgreement.
// Sem avaliador de risco de vínculo ainda (spec coloca isso na F3) e sem integração
// real de assinatura (Clicksign) — signatureStatus só guarda o dado.
model Contract {
  id              String          @id @default(cuid())
  companyId       String
  providerId      String
  templateId      String?
  version         Int             @default(1)
  content         String
  status          ContractStatus  @default(DRAFT)
  signatureStatus SignatureStatus @default(PENDING)
  signedAt        DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  company  Company           @relation(fields: [companyId], references: [id])
  provider Provider          @relation(fields: [providerId], references: [id])
  template ContractTemplate? @relation(fields: [templateId], references: [id])

  @@index([providerId])
  @@map("contracts")
}

// Ordem de Serviço (spec 4.5) — núcleo do sistema. Máquina de estados explícita:
// Supervisor cria -> Gerente aprova/recusa/pede ajuste -> Financeiro aprova/recusa/pede
// ajuste -> liberada pra faturamento (APPROVED). Todo pedido de ajuste reinicia o ciclo
// completo (volta pra PENDING_MANAGER_APPROVAL) em vez de permitir edição direta pelo
// aprovador — mantém o histórico de aprovação íntegro. Toda transição vai pro AuditLog
// (spec 3/4.12), não existe tabela própria de histórico de status aqui.
// Valores ficam em campos separados (nunca um "total" único) porque a composição do
// valor sustenta a tese de autonomia na defesa jurídica contra pejotização — o total é
// sempre calculado em runtime pelo service, nunca uma coluna própria (evita divergência).
// Anexar nota fiscal / gerar título financeiro / pagamento (Stark Bank) ficam fora desta
// fatia — pertencem ao módulo Financeiro (spec 4.9), que consome uma Ordem já APPROVED.
model ServiceOrder {
  id                    String             @id @default(cuid())
  companyId             String
  providerId            String
  commercialAgreementId String?
  description           String
  status                ServiceOrderStatus @default(PENDING_MANAGER_APPROVAL)

  baseValue      Decimal @db.Decimal(12, 2)
  bonus          Decimal @default(0) @db.Decimal(12, 2)
  commission     Decimal @default(0) @db.Decimal(12, 2)
  additionals    Decimal @default(0) @db.Decimal(12, 2)
  reimbursements Decimal @default(0) @db.Decimal(12, 2)
  adjustments    Decimal @default(0) @db.Decimal(12, 2)

  createdByUserId         String
  managerDecisionByUserId String?
  managerDecisionAt       DateTime?
  managerDecisionNote     String?
  financeDecisionByUserId String?
  financeDecisionAt       DateTime?
  financeDecisionNote     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company             Company              @relation(fields: [companyId], references: [id])
  provider            Provider             @relation(fields: [providerId], references: [id])
  commercialAgreement CommercialAgreement? @relation(fields: [commercialAgreementId], references: [id])
  createdBy           User                 @relation("ServiceOrderCreatedBy", fields: [createdByUserId], references: [id])
  managerDecisionBy   User?                @relation("ServiceOrderManagerDecision", fields: [managerDecisionByUserId], references: [id])
  financeDecisionBy   User?                @relation("ServiceOrderFinanceDecision", fields: [financeDecisionByUserId], references: [id])

  @@index([providerId])
  @@index([companyId, status])
  @@map("service_orders")
}

// Define QUAIS níveis existem na cadeia de aprovação de uma empresa (nome livre,
// definido pelo admin — "Supervisor", "Gerente", "Líder"...). Não diz quem ocupa
// cada nível nem quem reporta pra quem — isso é o HierarchyAssignment. Sem cargo
// fixo no código: o número de níveis e os nomes são inteiramente configuráveis.
model ApprovalLevel {
  id        String   @id @default(cuid())
  companyId String
  name      String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company               @relation(fields: [companyId], references: [id])
  assignments HierarchyAssignment[]

  @@unique([companyId, order])
  @@map("approval_levels")
}

// Árvore de pessoas — cada nó é uma pessoa ocupando um ApprovalLevel, com um
// parentId apontando pra quem está acima dela na cadeia (nulo = topo, ex.: um
// Gerente sem superior configurado). Um Provider aponta pro HierarchyAssignment
// da pessoa imediatamente responsável por ele (Provider.responsibleAssignmentId).
//
// Isso dirige DUAS coisas ao mesmo tempo, ambas derivadas subindo/descendo esta
// mesma árvore, nunca guardadas separadamente:
//   - Cadeia de aprovação de um lançamento: parte do responsibleAssignment do
//     Provider e sobe via parentId até o topo; depois disso sempre cai na etapa
//     fixa Financeiro (Role.FINANCEIRO/ADMIN, acesso global, não é um nível
//     configurável).
//   - Visibilidade: uma pessoa enxerga o próprio nó + toda a subárvore abaixo
//     dela (via children), nunca outros ramos. Financeiro é a única exceção,
//     com acesso global fixo por Role, não por posição na árvore.
model HierarchyAssignment {
  id              String   @id @default(cuid())
  companyId       String
  approvalLevelId String
  userId          String
  parentId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company       Company               @relation(fields: [companyId], references: [id])
  approvalLevel ApprovalLevel         @relation(fields: [approvalLevelId], references: [id])
  user          User                  @relation(fields: [userId], references: [id])
  parent        HierarchyAssignment?  @relation("HierarchyAssignmentParent", fields: [parentId], references: [id])
  children      HierarchyAssignment[] @relation("HierarchyAssignmentParent")
  providers     Provider[]

  @@index([companyId])
  @@index([parentId])
  @@map("hierarchy_assignments")
}
